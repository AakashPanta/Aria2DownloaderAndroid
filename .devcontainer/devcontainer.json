{
  "name": "Android Codespaces",
  "image": "mcr.microsoft.com/devcontainers/java:1-21-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/android-sdk:1": {},
    "ghcr.io/devcontainers/features/gradle:1": {
      "version": "8.7"
    }
  },
  "postCreateCommand": "chmod +x gradlew || true && sdkmanager --licenses || true",
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "Gradle.vscode-gradle",
        "redhat.vscode-xml"
      ]
    }
  }
}
